/*
 * BioSET Preprocessing - Nextflow Configuration
 * ================================================
 *
 * Profiles:
 *   - standard:   Local execution (development/testing)
 *   - nyu_hpc:    NYU Greene HPC cluster (SLURM + Singularity)
 *   - docker:     Docker container execution
 *   - singularity: Singularity container execution
 *
 * Usage:
 *   nextflow run main.nf -profile nyu_hpc [params...]
 *   nextflow run main.nf -profile docker [params...]
 */

// =========================================================================
// Default settings
// =========================================================================

manifest {
    name            = 'BioSET_Preprocessing'
    author          = 'NYU Visualization & Krueger Group'
    description     = 'GPU-accelerated spatial overlap analysis pipeline'
    version         = '1.0.0'
    nextflowVersion = '>=23.04'
    mainScript      = 'main.nf'
}

// Default output directory
params.outdir = 'bioset_results'

// =========================================================================
// Process labels → resource classes
// =========================================================================

process {
    // Default
    cpus   = 2
    memory = '8 GB'
    time   = '2h'

    withLabel: 'cpu_medium' {
        cpus   = 4
        memory = '16 GB'
        time   = '4h'
    }

    withLabel: 'cpu_large' {
        cpus   = 8
        memory = '32 GB'
        time   = '12h'
    }

    withLabel: 'gpu' {
        cpus   = 4
        memory = '32 GB'
        time   = '48h'
        // GPU allocation is profile-specific (see below)
    }
}

// =========================================================================
// Profiles
// =========================================================================

profiles {

    // ----- Local development -----
    standard {
        process.executor = 'local'
    }

    // ----- NYU Greene HPC (SLURM + Singularity) -----
    nyu_hpc {
        process {
            executor = 'slurm'
            queue    = 'cpu'  // default queue

            withLabel: 'gpu' {
                queue         = 'gpu'
                clusterOptions = '--gres=gpu:1 --constraint=a100'
                memory        = '64 GB'
                time          = '72h'
            }

            withLabel: 'cpu_large' {
                queue  = 'cpu'
                memory = '64 GB'
                time   = '24h'
            }
        }

        singularity {
            enabled    = true
            autoMounts = true
            cacheDir   = "${HOME}/.singularity/cache"
        }
    }

    // ----- Docker -----
    docker {
        docker.enabled = true
        docker.runOptions = '--gpus all'

        process {
            withLabel: 'gpu' {
                container = 'bioset-preprocessing:gpu'
            }
            withLabel: 'cpu_medium' {
                container = 'bioset-preprocessing:cpu'
            }
            withLabel: 'cpu_large' {
                container = 'bioset-preprocessing:cpu'
            }
        }
    }

    // ----- Singularity -----
    singularity {
        singularity {
            enabled    = true
            autoMounts = true
        }

        process {
            withLabel: 'gpu' {
                container = 'bioset-preprocessing_gpu.sif'
                containerOptions = '--nv'  // NVIDIA GPU support
            }
            withLabel: 'cpu_medium' {
                container = 'bioset-preprocessing_cpu.sif'
            }
            withLabel: 'cpu_large' {
                container = 'bioset-preprocessing_cpu.sif'
            }
        }
    }

    // ----- Testing (minimal resources) -----
    test {
        process.executor = 'local'
        process.cpus = 1
        process.memory = '4 GB'

        params {
            tile_size        = '64'
            channels         = '0,1,2'
            max_set_size     = 2
            hierarchy_levels = 2
            output_name      = 'test_run'
        }
    }

    nyu_torch {
        process {
            executor = 'slurm'
            beforeScript = """
                export PATH=/scratch/\$USER/envs/bioset/bin:\$PATH
                export PYTHONPATH=/scratch/\$USER/envs/bioset/lib/python3.11/site-packages:\$PYTHONPATH
                module load anaconda3/2025.06
                source /share/apps/anaconda3/2025.06/etc/profile.d/conda.sh
                conda activate /scratch/\$USER/envs/bioset
            """
            withLabel: 'gpu' {
                clusterOptions = '--account=torch_pr_608_general --gres=gpu:1'
                memory = '64 GB'
                time   = '24h'
                cpus   = 8
            }
            withLabel: 'cpu_large' {
                clusterOptions = '--account=torch_pr_608_general'
                memory = '128 GB'
                time   = '4h's|process.conda = '/scratch/\{$USER}/envs/bioset'|process.conda
                cpus   = 16
            }
            withLabel: 'cpu_medium' {
                clusterOptions = '--account=torch_pr_608_general'
                memory = '32 GB'
                time   = '2h'
                cpus   = 8
            }
        }
        conda {
            enabled = true
        }
        process.conda = "/scratch/${System.getenv('USER')}/envs/bioset"
    }
}

// =========================================================================
// Reporting
// =========================================================================

timeline {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/timeline.html"
    overwrite = true
}

report {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/report.html"
    overwrite = true
}

trace {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/trace.txt"
    overwrite = true
    fields    = 'task_id,hash,native_id,name,status,exit,submit,duration,realtime,cpus,memory,rss,peak_rss'
}

dag {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/dag.html"
    overwrite = true
}

// =========================================================================
// Cleanup
// =========================================================================

cleanup = false 
